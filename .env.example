# WTCell — environment variable template
# Copy this file to `.env` and fill in your values.
# NEVER commit the filled-in `.env` file to version control.

# ---------------------------------------------------------------------------
# PostgreSQL connection settings
# ---------------------------------------------------------------------------
NEON_DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ---------------------------------------------------------------------------
# OpenAI API key — required for literature confidence scoring
# ---------------------------------------------------------------------------
# Obtain your key at https://platform.openai.com/api-keys
# The literature check feature is silently disabled if this is not set.
OPENAI_API_KEY=sk-...

# Optional: override the OpenAI model used for literature checks.
# Default: gpt-4o-mini  (cost-effective and well-suited for this task)
# OPENAI_MODEL=gpt-4o-mini
