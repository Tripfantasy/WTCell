# WTCell — Streamlit secrets template
# ====================================
# For LOCAL development:
#   Copy this file to .streamlit/secrets.toml and fill in your values.
#   .streamlit/secrets.toml is listed in .gitignore and must NEVER be committed.
#
# For STREAMLIT COMMUNITY CLOUD deployment:
#   Do NOT upload this file. Instead, paste the key=value pairs below into the
#   "Secrets" text box in your app's Streamlit Cloud settings
#   (App settings → Secrets).
#   Streamlit Cloud will make them available via st.secrets at runtime.
#
# These values mirror the environment variables in .env.example.
# If both .env and st.secrets provide a key, the .env / environment variable
# takes precedence (the app only reads st.secrets for keys that are absent
# from the environment).

# ---------------------------------------------------------------------------
# PostgreSQL connection settings
# ---------------------------------------------------------------------------
NEON_DATABASE_URL = "postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ---------------------------------------------------------------------------
# OpenAI API key — required for literature confidence scoring
# ---------------------------------------------------------------------------
OPENAI_API_KEY = "sk-..."

# Optional: override the OpenAI model (default: gpt-4o-mini)
# OPENAI_MODEL = "gpt-4o-mini"
